{
  "name": "sink-cli",
  "version": "0.1.0",
  "description": "Data hygiene for music PR — scrub, rinse, soak your contact lists",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sink": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "deep-email-validator": "^0.1.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "nanoid": "^5.1.0",
    "openai": "^4.80.0",
    "ora": "^8.0.0",
    "react": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.10",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "music",
    "pr",
    "contacts",
    "email",
    "validation",
    "deduplication",
    "enrichment",
    "csv",
    "data-hygiene"
  ],
  "homepage": "https://github.com/totalaudiopromo/sink-cli#readme",
  "bugs": {
    "url": "https://github.com/totalaudiopromo/sink-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/totalaudiopromo/sink-cli.git"
  },
  "author": "Total Audio Promo",
  "files": [
    "dist",
    "data"
  ]
}
