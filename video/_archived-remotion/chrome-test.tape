Output video/out/chrome-test.gif

Set Shell "bash"
Set FontFamily "Menlo"
Set FontSize 14
Set Width 900
Set Height 300
Set Theme "Catppuccin Mocha"
Set Padding 16
Set Framerate 10
Set WindowBar Colorful
Set Margin 20
Set MarginFill "#06b6d4"
Set BorderRadius 10

Env PS1 "$ "

Type "echo 'Window chrome test'"
Enter
Sleep 2s
